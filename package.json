{
  "name": "cadastre-looker",
  "version": "1.0.0",
  "private": true,
  "description": "Explore French cadastre parcels by size, with results shown on a map",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist-lambda/lambda.cjs",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
